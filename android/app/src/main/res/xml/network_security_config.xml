<?xml version="1.0" encoding="utf-8"?>
<!--
  Transport security for RELEASE builds (see docs/ComplianceAudit.md C3).

  Cleartext (HTTP) is FORBIDDEN. All traffic must be HTTPS/TLS, so credentials, tokens, and
  behavioral data are never sent in the clear.

  Local development uses plain HTTP against a LAN/emulator server. That is handled by a separate
  debug-only config at `src/debug/res/xml/network_security_config.xml`, which Gradle substitutes
  for THIS file in debug builds only. No development hosts/IPs are hardcoded here, so nothing
  environment-specific is shipped or committed in the release config.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
